# Setwise Router environment configuration
# Copy to .env and fill in values. Never commit .env files.

# --- RPC endpoints (one per supported chain) ---
# Primary RPCs may require credentials; never commit real URLs.
RPC_URL_ETHEREUM=https://eth-mainnet.example.com
RPC_URL_BSC=https://bsc-mainnet.example.com
RPC_URL_BASE=https://base-mainnet.example.com
RPC_URL_ROBINHOOD=https://robinhood-chain.example.com

# --- Archive RPCs (baseline capture / fork tests; one per chain) ---
RPC_ARCHIVE_URL_ETHEREUM=https://eth-archive.example.com
RPC_ARCHIVE_URL_BSC=https://bsc-archive.example.com
RPC_ARCHIVE_URL_BASE=https://base-archive.example.com
RPC_ARCHIVE_URL_ROBINHOOD=https://robinhood-archive.example.com

# --- Quote service ---
QUOTE_SERVICE_PORT=3000
QUOTE_SERVICE_LOG_LEVEL=info

# --- 0x Swap API (server-side only; never expose to clients) ---
ZEROEX_API_KEY=

# --- Setwise RFQ ---
SETWISE_RFQ_API_URL=https://rfq.setwise.example.com
SETWISE_POOL_SIGNER_ADDRESS=0x0000000000000000000000000000000000000000

# --- Deployment (do NOT commit real keys) ---
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
BASESCAN_API_KEY=

# --- Foundry ---
FORGE_BIN=
