{
  "openapi": "3.1.0",
  "info": {
    "title": "Setwise Router Quote API",
    "version": "1.0.0",
    "description": "Chain-aware normalized quotes from ZFi, aggregators, and Set sources."
  },
  "paths": {
    "/v1/quotes": {
      "post": {
        "operationId": "createQuote",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/QuoteRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Normalized indicative or firm quote",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QuoteResponse" }
              }
            }
          },
          "400": {
            "description": "Stable validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiVersion": { "type": "string", "const": "v1" },
      "Uint": { "type": "string", "pattern": "^(0|[1-9][0-9]*)$" },
      "PositiveUint": { "type": "string", "pattern": "^[1-9][0-9]*$" },
      "Address": {
        "type": "string",
        "pattern": "^0x[0-9a-fA-F]{40}$",
        "not": { "const": "0x0000000000000000000000000000000000000000" }
      },
      "ChainAddress": {
        "type": "object",
        "additionalProperties": false,
        "required": ["chainId", "address"],
        "properties": {
          "chainId": { "type": "integer", "minimum": 1 },
          "address": { "$ref": "#/components/schemas/Address" }
        }
      },
      "SlippagePolicy": {
        "type": "object",
        "additionalProperties": false,
        "required": ["maxBps"],
        "properties": {
          "maxBps": { "type": "integer", "minimum": 0, "maximum": 10000 }
        }
      },
      "QuoteRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "apiVersion",
          "chainId",
          "tokenIn",
          "tokenOut",
          "router",
          "mode",
          "amount",
          "recipient",
          "funder",
          "slippage"
        ],
        "properties": {
          "apiVersion": { "$ref": "#/components/schemas/ApiVersion" },
          "chainId": { "type": "integer", "enum": [1, 56, 4663, 8453] },
          "tokenIn": { "$ref": "#/components/schemas/ChainAddress" },
          "tokenOut": { "$ref": "#/components/schemas/ChainAddress" },
          "router": { "$ref": "#/components/schemas/ChainAddress" },
          "mode": { "type": "string", "enum": ["exact-input", "exact-output"] },
          "amount": { "$ref": "#/components/schemas/PositiveUint" },
          "recipient": { "$ref": "#/components/schemas/ChainAddress" },
          "funder": { "$ref": "#/components/schemas/ChainAddress" },
          "slippage": { "$ref": "#/components/schemas/SlippagePolicy" }
        }
      },
      "Source": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "displayName"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["zfi", "aggregator", "setwise"] },
          "displayName": { "type": "string", "minLength": 1 },
          "poolId": {
            "type": "string",
            "minLength": 1,
            "description": "Internal Set pool identifier; required when type is setwise."
          }
        }
      },
      "Evidence": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "observedAt", "reference"],
        "properties": {
          "kind": { "type": "string", "enum": ["onchain", "http", "simulation", "policy"] },
          "observedAt": { "type": "string", "format": "date-time" },
          "reference": { "type": "string", "minLength": 1 },
          "blockNumber": { "$ref": "#/components/schemas/Uint" },
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 }
        }
      },
      "Amounts": {
        "type": "object",
        "additionalProperties": false,
        "required": ["input", "output", "limit"],
        "properties": {
          "input": { "$ref": "#/components/schemas/PositiveUint" },
          "output": { "$ref": "#/components/schemas/PositiveUint" },
          "limit": {
            "allOf": [{ "$ref": "#/components/schemas/PositiveUint" }],
            "description": "Minimum output for exact-input or maximum input for exact-output."
          }
        }
      },
      "Gas": {
        "type": "object",
        "additionalProperties": false,
        "required": ["estimatedUnits", "estimatedCost"],
        "properties": {
          "estimatedUnits": { "$ref": "#/components/schemas/Uint" },
          "estimatedCost": { "$ref": "#/components/schemas/Uint" }
        }
      },
      "Fee": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "amount", "token"],
        "properties": {
          "type": { "type": "string", "enum": ["network", "protocol", "source"] },
          "amount": { "$ref": "#/components/schemas/Uint" },
          "token": { "$ref": "#/components/schemas/ChainAddress" }
        }
      },
      "NormalizedQuote": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "amounts", "gas", "fees", "approvalTarget", "expiresAt"],
        "properties": {
          "kind": { "type": "string", "enum": ["indicative", "firm"] },
          "amounts": { "$ref": "#/components/schemas/Amounts" },
          "gas": { "$ref": "#/components/schemas/Gas" },
          "fees": { "type": "array", "items": { "$ref": "#/components/schemas/Fee" } },
          "approvalTarget": {
            "oneOf": [{ "$ref": "#/components/schemas/ChainAddress" }, { "type": "null" }]
          },
          "expiresAt": { "type": ["string", "null"], "format": "date-time" }
        }
      },
      "SourceOutcome": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "status", "quote", "evidence"],
        "properties": {
          "source": { "$ref": "#/components/schemas/Source" },
          "status": {
            "type": "string",
            "enum": ["available", "unavailable", "excluded", "stale", "failed"]
          },
          "quote": {
            "oneOf": [{ "$ref": "#/components/schemas/NormalizedQuote" }, { "type": "null" }]
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/components/schemas/Evidence" }
          }
        }
      },
      "Transaction": {
        "type": "object",
        "additionalProperties": false,
        "required": ["chainId", "to", "calldata", "value"],
        "properties": {
          "chainId": { "type": "integer", "minimum": 1 },
          "to": { "$ref": "#/components/schemas/Address" },
          "calldata": { "type": "string", "pattern": "^0x([0-9a-fA-F]{2})*$" },
          "value": { "$ref": "#/components/schemas/Uint" }
        }
      },
      "QuoteResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "apiVersion",
          "requestId",
          "chainId",
          "mode",
          "kind",
          "selectedSourceId",
          "sources",
          "transaction"
        ],
        "properties": {
          "apiVersion": { "$ref": "#/components/schemas/ApiVersion" },
          "requestId": { "type": "string", "minLength": 1 },
          "chainId": { "type": "integer", "enum": [1, 56, 4663, 8453] },
          "mode": { "type": "string", "enum": ["exact-input", "exact-output"] },
          "kind": { "type": "string", "enum": ["indicative", "firm"] },
          "selectedSourceId": { "type": ["string", "null"], "minLength": 1 },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/components/schemas/SourceOutcome" }
          },
          "transaction": {
            "oneOf": [{ "$ref": "#/components/schemas/Transaction" }, { "type": "null" }]
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["apiVersion", "error"],
        "properties": {
          "apiVersion": { "$ref": "#/components/schemas/ApiVersion" },
          "error": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "message"],
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "QUOTE_INVALID_REQUEST",
                  "QUOTE_INVALID_RESPONSE",
                  "QUOTE_UNSUPPORTED_API_VERSION",
                  "QUOTE_UNSUPPORTED_CHAIN",
                  "QUOTE_CHAIN_MISMATCH",
                  "QUOTE_ROUTER_MISMATCH",
                  "QUOTE_INVALID_ADDRESS",
                  "QUOTE_INVALID_AMOUNT",
                  "QUOTE_INVALID_SLIPPAGE",
                  "QUOTE_SOURCE_EVIDENCE_REQUIRED",
                  "QUOTE_AMBIGUOUS_EXECUTION"
                ]
              },
              "message": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "details": {}
            }
          }
        }
      }
    }
  }
}
