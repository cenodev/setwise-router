{
  "name": "setwise-router",
  "private": true,
  "version": "0.0.0",
  "description": "Setwise Router — ZFi baseline import and multi-chain Setwise routing program",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "services/quote",
    "app"
  ],
  "scripts": {
    "build": "npm run build:contracts && npm run build:services",
    "build:contracts": "node scripts/build-zfi-baseline.mjs",
    "build:contracts:zquoter": "node scripts/build-zquoter-profile.mjs",
    "build:services": "npm run build --workspace=@setwise-router/app",
    "test": "node --test test/*.test.js",
    "test:contracts": "node scripts/test-contracts.mjs",
    "test:services": "npm run test --workspace=@setwise-router/quote",
    "lint": "node scripts/syntax-check.mjs",
    "lint:services": "npm run lint --workspace=@setwise-router/quote",
    "typecheck": "node scripts/syntax-check.mjs",
    "format": "node scripts/format-check.mjs",
    "format:fix": "node scripts/format-check.mjs --fix",
    "clean": "node scripts/clean.mjs",
    "check:bytecode": "node scripts/check-bytecode-size.mjs",
    "check": "npm run lint && npm run typecheck && npm run format && npm run test && npm run test:services && npm run build:services && npm run check:bytecode && npm run test:contracts",
    "baseline:abi": "node scripts/build-abi-baseline.mjs && node scripts/build-abi-docs.mjs",
    "baseline:routes": "node scripts/build-route-fixtures.mjs",
    "baseline:capture": "node scripts/capture-execution-fixtures.mjs"
  }
}
